GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

STRIPE_SECRET_KEY=
STRIPE_PRICE_PREMIUM_MONTHLY=
STRIPE_PRICE_PREMIUM_YEARLY=
STRIPE_WEBHOOK_SECRET=

# OpenAI — powers the AI Tutor.
# If OPENAI_API_KEY is unset, the tutor falls back to the rule-based engine.
# OPENAI_TUTOR_MODEL is optional; default is gpt-4o-mini ($0.15/M in, $0.60/M out).
# Other reasonable choices: gpt-5-nano ($0.05/M in, $0.40/M out).
OPENAI_API_KEY=
OPENAI_TUTOR_MODEL=

# App Store review / demo account.
# If unset, no bootstrap test account is created.
# Set these in Vercel before submitting to Apple (App Review needs a working demo login).
TEST_ACCOUNT_EMAIL=
TEST_ACCOUNT_PASSWORD=
TEST_ACCOUNT_NAME=
